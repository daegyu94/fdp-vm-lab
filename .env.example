# Copy this file to .env and override only what you need.
# Paths may be absolute or relative to this repository.

GUEST_MEMORY=8G
GUEST_CPUS=8
GUEST_SSH_PORT=18080
GUEST_USERNAME=warp

FDP_SSD_SIZE_MB=229376
FDP_NRUH=8
FDP_NRG=1
FDP_PLACEMENT_HANDLES='0;1;2;3;4;5;6;7'
FDP_READ_LATENCY_NS=10000
FDP_WRITE_LATENCY_NS=5000
FDP_ERASE_LATENCY_NS=20000
FDP_GC_THRESHOLD=90
FDP_GC_THRESHOLD_HIGH=99

LMCACHE_REPOSITORY_URL=https://github.com/LMCache/LMCache.git
LMCACHE_REPOSITORY_BRANCH=dev
LMCACHE_REPOSITORY_COMMIT=
# LMCACHE_SOURCE_PATH=/absolute/path/to/LMCache
LMCACHE_INSTALL_ENABLED=0

