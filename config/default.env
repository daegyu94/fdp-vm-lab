# Pinned WARP/FEMU source
WARP_REPOSITORY_URL=https://github.com/MoatLab/WARP-earlyaccess.git
WARP_REF=ce587fba515963b7ed0e85de4ab5db11536cad8f
WARP_FETCH_REF=refs/heads/fdp
WARP_SOURCE_DIR=third_party/WARP-earlyaccess
WARP_BUILD_DIR=third_party/WARP-earlyaccess/build-femu

# Pinned Ubuntu Server 24.04 LTS amd64 cloud image (2026-06-15)
GUEST_BASE_IMAGE_URL=https://cloud-images.ubuntu.com/noble/20260615/noble-server-cloudimg-amd64.img
GUEST_BASE_IMAGE_SHA256=5fa5b05e5ec239858c4531485d6023b0896448c2df7c63b34f8dae6ea6051a44
GUEST_BASE_IMAGE_PATH=images/ubuntu-24.04-base-amd64.img
GUEST_IMAGE_PATH=images/ubuntu-24.04-warp-fdp.qcow2
GUEST_IMAGE_SIZE=40G
GUEST_MEMORY=8G
GUEST_CPUS=8
GUEST_SSH_PORT=18080
GUEST_USERNAME=warp
GUEST_SSH_TIMEOUT=900
GUEST_CLOUD_INIT_TIMEOUT=7200

# WARP FDP geometry and latency. The geometry follows the fdp branch script.
FDP_SSD_SIZE_MB=16384
FDP_NRUH=8
FDP_NRG=1
FDP_PLACEMENT_HANDLES='0;1;2;3;4;5;6;7'
FDP_READ_LATENCY_NS=10000
FDP_WRITE_LATENCY_NS=5000
FDP_ERASE_LATENCY_NS=20000
FDP_GC_THRESHOLD=90
FDP_GC_THRESHOLD_HIGH=99

# LMCache source. Set LMCACHE_SOURCE_PATH to a host checkout to provision via 9p.
LMCACHE_REPOSITORY_URL=https://github.com/LMCache/LMCache.git
LMCACHE_REPOSITORY_BRANCH=dev
LMCACHE_REPOSITORY_COMMIT=cc9b0f51bedf44ef711f7a079aaa4b4082a4f392
LMCACHE_SOURCE_PATH=
LMCACHE_INSTALL_ENABLED=0

# Host bootstrap behavior
HOST_INSTALL_PACKAGES=1

